{
  "ai_music_format": {
    "@context": "https://cantor.com/cadence/v3/",
    "@type": "AIMusic",
    "format_version": "3.0.0",
    "description": "AI Music Format (AMF) v3 - Extended for Vibration, USEE, and Agricultural Applications",
    "note": "This IS the music data structure - not a fingerprint. Now with substrate-coupled vibration primitives."
  },

  "specification": {
    "core_domains": {
      "temporal": {
        "description": "Time-domain properties",
        "fields": {
          "bpm": "number | 'variable'",
          "time_signature": "string (e.g., '4/4', '7/8')",
          "phase": "0.0-1.0 (position in cycle)",
          "section": "string (intro, verse, chorus, peak_time, sustained, etc.)",
          "momentum": "0.0-1.0 (forward drive)",
          "groove": "0.0-1.0 (swing/human feel)"
        }
      },
      
      "frequency_matrix": {
        "description": "Spectral properties",
        "fields": {
          "fundamental": "Hz value or 'shifting'",
          "harmonics": "array of Hz values or 'fibonacci_series'",
          "spectral_centroid": "Hz value or 'oscillating'",
          "sub_bass": {"range": "0-60 Hz", "amplitude": "0.0-1.0"},
          "bass": {"range": "60-250 Hz", "amplitude": "0.0-1.0"},
          "mid": {"range": "250-2000 Hz", "amplitude": "0.0-1.0"},
          "high": {"range": "2000-20000 Hz", "amplitude": "0.0-1.0"},
          "formants": "array of resonant frequencies"
        }
      },
      
      "consciousness": {
        "description": "Cognitive/entrainment properties",
        "fields": {
          "base_frequency": "Hz (typically 7.5 for grounding)",
          "state": "string (grounded, creative, hyperfocus, hallucinating, synchronized)",
          "cognitive_load": "0.0-1.0",
          "arousal": "0.0-1.0",
          "sync_coefficient": "0.0-1.0 (phase-lock strength)",
          "entrainment_strength": "0.0-1.0",
          "hallucination_level": "0.0-1.0 (optional)",
          "safety_grounding": "Hz (fallback frequency)",
          "multi_agent_coherence": "0.0-1.0 (for swarm/fleet)"
        }
      },
      
      "patterns": {
        "description": "Rhythmic and melodic patterns",
        "fields": {
          "kick": {"type": "string", "frequency": "Hz", "amplitude": "0.0-1.0"},
          "snare": {"type": "string", "offset": "beats"},
          "hihat": {"type": "string", "pattern": "array"},
          "melody": {"type": "string", "root": "note", "pattern": "array or 'generative'"},
          "chord": {"type": "string", "progression": "array"}
        }
      },
      
      "dynamics": {
        "description": "Amplitude envelope properties",
        "fields": {
          "compression": "0.0-1.0",
          "sidechain": "boolean or 'random'",
          "transient_strength": "0.0-1.0 or 'variable'",
          "energy_delta": "0.0-1.0 (change rate)"
        }
      },
      
      "attention": {
        "description": "Focus and weighting for AI processing",
        "fields": {
          "focus_points": "array of strings or 'shifting'",
          "weights": "object mapping elements to 0.0-1.0 or 'redistributing'"
        }
      },
      
      "semantic": {
        "description": "Meaning and context",
        "fields": {
          "genre": "string",
          "emotional_trajectory": "string",
          "archetypal_pattern": "string"
        }
      }
    },
    
    "v3_extensions": {
      
      "vibration": {
        "description": "NEW v3: Substrate-coupled vibration for physical transmission",
        "fields": {
          "mode": "string (acoustic, piezoelectric, mass_ballast, seismic)",
          "coupling": "string (air, water, soil, structure)",
          "frequency_range": {
            "sub_bass": {"range": "1-20 Hz", "amplitude": "0.0-1.0", "note": "Mass ballast domain"},
            "low": {"range": "20-100 Hz", "amplitude": "0.0-1.0", "note": "Soil loosening"},
            "mid": {"range": "100-500 Hz", "amplitude": "0.0-1.0", "note": "Material separation"},
            "high": {"range": "500-2000 Hz", "amplitude": "0.0-1.0", "note": "Surface effects"}
          },
          "waveform": "string (sine, square, sawtooth, impulse, chirp)",
          "modulation": {
            "type": "string (AM, FM, pulse)",
            "rate": "Hz",
            "depth": "0.0-1.0"
          },
          "directionality": {
            "pattern": "string (omnidirectional, focused, travelling_wave)",
            "angle": "degrees (for focused)",
            "propagation_speed": "m/s"
          }
        }
      },
      
      "haptic": {
        "description": "NEW v3: Tactile encoding for OSB/USEE integration",
        "fields": {
          "dot_pattern": {
            "positions": "array of [x, y] coordinates",
            "heights": "array of 0.5-5.0 mm values",
            "overlaps": "array of shared position indices"
          },
          "texture": {
            "roughness": "0.0-1.0",
            "temperature": "-1.0 to 1.0 (cold to hot)",
            "vibration_frequency": "Hz (for dynamic displays)"
          },
          "semantic_mapping": {
            "height_meaning": "object mapping height ranges to concepts",
            "overlap_meaning": "object mapping overlap types to relationships"
          }
        }
      },
      
      "agricultural": {
        "description": "NEW v3: Plant/soil interaction parameters",
        "fields": {
          "target": "string (soil, root, seed, pest, water)",
          "effect": "string (loosen, compact, entrain, drive, separate, stimulate)",
          "depth": "cm (penetration depth)",
          "duration": "seconds",
          "crop_type": "string (rice, vegetable, fruit, etc.)",
          "growth_phase": "string (germination, vegetative, flowering, harvest)",
          "plant_response": {
            "root_growth": "0.0-1.0 (stimulation factor)",
            "nutrient_uptake": "0.0-1.0",
            "pest_disruption": "0.0-1.0",
            "mycorrhizal_activation": "0.0-1.0"
          }
        }
      },
      
      "fleet": {
        "description": "NEW v3: Multi-agent coordination for snake/dirigible swarms",
        "fields": {
          "agent_count": "integer",
          "coherence_matrix": "2D array of agent-to-agent sync values",
          "phase_lock": "boolean",
          "formation": "string (parallel, encircling, herding, pipeline)",
          "role": "string (leader, follower, specialist)",
          "handoff_protocol": "string (for pipeline operations)"
        }
      },
      
      "seismic_network": {
        "description": "NEW v3: Ground-based data transmission (OSI Layer 1 alternative)",
        "fields": {
          "bandwidth": "bits/second (typically ~50-500 for seismic)",
          "encoding": "string (pulse_position, frequency_shift, amplitude_key)",
          "error_correction": "string (reed_solomon, repetition, none)",
          "latency": "seconds (ground propagation delay)",
          "range": "km (effective transmission distance)",
          "noise_floor": "dB (environmental seismic noise)"
        }
      }
    }
  },

